create database retail_db;

use retail_db;

create table Customers(customer_id int primary key, name varchar(50),city varchar(50));

create table Products(product_id int primary key,name varchar(50),category varchar(50),price decimal(10,2));

create table Orders(order_id int primary key,customer_id int, date date,
                    foreign key(customer_id) references Customers(customer_id));

create table Order_Items(order_id int,product_id int,quantity int,foreign key(order_id) references Orders(order_id),
                         foreign key(product_id) references Products(product_id));
              
