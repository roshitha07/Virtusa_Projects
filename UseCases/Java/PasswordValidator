import java.util.*;

public class PasswordValidator {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);
        String password;

        while (true) {

            System.out.print("Enter a password: ");
            password = scanner.nextLine();

            boolean hasUpper = false;
            boolean hasDigit = false;
            boolean lengthValid = false;

            if (password.length() >= 8) {
                lengthValid = true;
            }

            for (int i = 0; i < password.length(); i++) {
                char ch = password.charAt(i);

                if (Character.isUpperCase(ch)) {
                    hasUpper = true;
                }

                if (Character.isDigit(ch)) {
                    hasDigit = true;
                }
            }

            if (!lengthValid) {
                System.out.println("Password too short. Must be at least 8 characters.");
            }

            if (!hasUpper) {
                System.out.println("Missing an uppercase letter.");
            }

            if (!hasDigit) {
                System.out.println("Missing a digit.");
            }

            if (lengthValid && hasUpper && hasDigit) {
                System.out.println("Password accepted! Strong password.");
                break;
            }

            System.out.println("Please try again.\n");
        }

        scanner.close();
    }
}
