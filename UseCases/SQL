create database Digital_Library;

use Digital_Library;

create table Books (
    BookID int primary key,
    Title varchar(100),
    Author varchar(100),
    Category varchar(50),
    AvailableCopies int
);

create table Students (
    StudentID int primary key,
    StudentName varchar(100),
    Email varchar(100),
    JoinDate date
);

create table IssuedBooks( IssueID int primary key, BookID int,StudentID int,IssueDate date,ReturnDate date,
                         foreign key(BookID) references Books(BookID),foreign key(StudentID) references Students(StudentID));

